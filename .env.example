# Shared BusMind local configuration.
# Copy this file to `.env` in the repository root and fill in real secrets.

# Database
DATABASE_URL=mysql+pymysql://CHANGE_ME_USER:CHANGE_ME_PASSWORD@127.0.0.1:3307/busmind?charset=utf8mb4
AUTO_CREATE_TABLES=false
VALIDATE_DB_SCHEMA_ON_STARTUP=false

# LTA DataMall
LTA_ACCOUNT_KEY=CHANGE_ME_LTA_ACCOUNT_KEY
LTA_BASE_URL=https://datamall2.mytransport.sg/ltaodataservice
LTA_TIMEOUT_SECONDS=12

# DeepSeek
DEEPSEEK_API_KEY=CHANGE_ME_DEEPSEEK_KEY
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_TIMEOUT_SECONDS=60
DEEPSEEK_MAX_TOKENS=1200
DEEPSEEK_TEMPERATURE=0.2

# Backend auth and email
SECRET_KEY=CHANGE_ME_SECRET_KEY
QQ_MAIL_HOST=smtp.qq.com
QQ_MAIL_PORT=465
QQ_MAIL_USERNAME=
QQ_MAIL_AUTH_CODE=
QQ_MAIL_FROM_NAME=BusMind

# TabPFN
TABPFN_TOKEN=CHANGE_ME_TABPFN_KEY
TABPFN_NO_BROWSER=1

# Candidate route scoring model
# Supported values: linear, xgboost, tabpfn
# Recommended default: xgboost
BUSMIND_SCORING_MODEL=xgboost