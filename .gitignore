# BusMind gitignore
# Commit source code, scripts, docs, config templates, algorithm datasets, and small hand-written assets.
# Do not commit local secrets, raw/processed LTA dumps, caches, or build outputs.

# OS / editor
.DS_Store
Thumbs.db
desktop.ini
.idea/
.vscode/
*.swp
*.swo
*.tmp

# Local environment and secrets
.env
.env.*
!.env.example
!backend/.env.example
*.pem
*.key
*.crt
credentials.json
token.json
service-b.env
/service-b.env

# Python runtime
__pycache__/
*.py[cod]
*$py.class
.python-version
.venv/
venv/
env/
.pytest_cache/
pytest-cache-files-*/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# uv
.uv-cache/

# Node / frontend
node_modules/
frontend/node_modules/
dist/
build/
frontend/dist/
frontend/build/
.vite/
frontend/.vite/
.cache/
coverage/
frontend/coverage/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Logs
*.log
logs/
backend/logs/

# Local database/runtime files
*.sqlite
*.sqlite3
*.db
*.dump
*.sql.gz

# LTA raw data: keep collectors and docs, ignore downloaded payloads/snapshots
data/raw/*
!data/raw/README.md
!data/raw/.gitkeep
!data/raw/collect_scripts/
!data/raw/collect_scripts/**
data/raw/lta/
data/raw/collect_scripts/__pycache__/
data/raw/collect_scripts/**/*.pyc*

# Processed data: keep processing scripts/docs, ignore generated CSV outputs
data/processed/*
!data/processed/README.md
!data/processed/.gitkeep
!data/processed/process_scripts/
!data/processed/process_scripts/**
data/processed/process_scripts/__pycache__/
data/processed/process_scripts/**/*.pyc*
data/processed/*.csv

# Legacy model files outside algorithm/model stay local unless explicitly moved.
algorithm/model_files/*
!algorithm/model_files/.gitkeep
*.pkl
*.joblib
*.model
*.onnx
!algorithm/dataset/**/*.pkl
!algorithm/model/**/*.pkl
!algorithm/model/**/*.joblib
!algorithm/model/**/*.model
!algorithm/model/**/*.onnx

# Database generated backups/exports
database/backup/
database/mock/
database/seed/

# Algorithm dataset snapshots are part of the algorithm deliverable.
# Keep data, labels, prompts, responses, summaries, and evaluation-ready files versionable.
!algorithm/dataset/
!algorithm/dataset/**
algorithm/dataset/**/__pycache__/
algorithm/dataset/**/*.py[cod]
algorithm/dataset/**/*.log
algorithm/dataset/**/*.tmp

# Keep intentional empty directories when they are still used
!**/.gitkeep
