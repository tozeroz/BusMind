# 服务端 B 独立配置文件。
# 复制到项目根目录并命名为 service-b.env，不要命名为 .env。

DEEPSEEK_API_KEY=请填写新创建的DeepSeek_API_Key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_TIMEOUT_SECONDS=20
DEEPSEEK_MAX_TOKENS=700
DEEPSEEK_TEMPERATURE=0.2

# LTA 可选。不使用时请留空，不要保留中文占位符。
LTA_ACCOUNT_KEY=
LTA_BASE_URL=https://datamall2.mytransport.sg/ltaodataservice
LTA_TIMEOUT_SECONDS=12

BUSMIND_TIMEZONE=Asia/Shanghai
BUSMIND_DEFAULT_CAPACITY=60
BUSMIND_WALKING_SPEED_MPS=1.2
BUSMIND_WALKING_ROAD_FACTOR=1.25
BUSMIND_WEIGHT_LOAD=0.50
BUSMIND_WEIGHT_WALK=0.30
BUSMIND_WEIGHT_TRANSFER=0.20
BUSMIND_ETA_PREDICTOR=algorithm.eta_prediction.models.predict_eta:predict_eta
BUSMIND_LOAD_PREDICTOR=algorithm.load_prediction.models.predict_load:predict_load
